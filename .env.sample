#build
TAG=latest
DOCKER_REGISTRY=openagri-eu
SOURCE_REPO=https://github.com/openagri-eu/openagri-pestanddiseasemanagement
## DB
VITE_API_URL=https://gk.test.horizon-openagri.eu/api/
SERVICE_PORT=8007
## theme (build-time, baked into bundle)
VITE_PRIMARY_COLOR="#558bc9"
VITE_SECONDARY_COLOR="#c8cc27"
VITE_BACKGROUND_DEFAULT="#fffdf5"
VITE_BACKGROUND_PAPER="#fffbeb"
## branding (build-time, baked into bundle + manifest)
VITE_APP_NAME="OpenAgri-UserDashboard"
VITE_APP_SHORT_NAME="OAUserDash"
VITE_APP_DESCRIPTION="Dashboard for all OpenAgri services"
## optional logo override; if set, fetched and replaces public/logo.png before generate-pwa-assets
LOGO_URL=
